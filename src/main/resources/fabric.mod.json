{
	"schemaVersion": 1,
	"id": "better-title-command",
	"version": "${version}",
	"name": "Better Title Command",
	"description": "Enhanced title command with text group management, transform effects, and permanent display support.",
	"authors": [
		"xiaoqibushixiaoq"
	],
	"contact": {
		"homepage": "https://github.com/xiaoqibushixiaoq/better-title-command-template-1.21.1",
		"sources": "https://github.com/xiaoqibushixiaoq/better-title-command-template-1.21.1",
		"issues": "https://github.com/xiaoqibushixiaoq/better-title-command-template-1.21.1/issues"
	},
	"license": "MIT",
	"icon": "assets/better-title-command/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.better.title.command.BetterTitleCommand"
		],
		"client": [
			"com.better.title.command.client.BetterTitleCommandClient"
		],
		"fabric-datagen": [
			"com.better.title.command.client.BetterTitleCommandDataGenerator"
		]
	},
	"mixins": [
		"better-title-command.mixins.json",
		{
			"config": "better-title-command.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.15.0",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}